{
  "$schema": "https://busibox.io/schemas/app-manifest-v1.json",
  "name": "Project Status Tracker",
  "id": "busibox-projects",
  "version": "1.0.0",
  "description": "Track and visualize the status of initiatives with intelligent status updates via conversational AI agents.",
  "icon": "BarChart3",
  "defaultPath": "/projects",
  "defaultPort": 3003,
  "healthEndpoint": "/api/health",
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "appMode": "frontend",
  "requiredEnvVars": [
    "DATA_API_URL",
    "AGENT_API_URL"
  ],
  "optionalEnvVars": [
    "NEXT_PUBLIC_DEBUG"
  ],
  "busiboxAppVersion": "^2.1.39"
}
