{
  "$schema": "https://busibox.io/schemas/app-manifest-v1.json",
  "name": "AI Initiative Status",
  "id": "status-report",
  "version": "1.0.0",
  "description": "Track and visualize the status of AI initiatives with intelligent status updates via conversational AI agents.",
  "icon": "BarChart3",
  "defaultPath": "/status",
  "defaultPort": 3003,
  "healthEndpoint": "/api/health",
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "appMode": "frontend",
  "database": {
    "required": false
  },
  "requiredEnvVars": [
    "DATA_API_URL",
    "AGENT_API_URL"
  ],
  "optionalEnvVars": [
    "NEXT_PUBLIC_DEBUG"
  ],
  "busiboxAppVersion": "^2.1.34"
}
